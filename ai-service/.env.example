SCRAPER_API_KEY=
GEMINI_API_KEY=
JOB_SCRAPER_SITES=indeed,linkedin,naukri
JOB_SCRAPER_RESULTS_PER_QUERY=10
JOB_SCRAPER_HOURS_OLD=168
JOB_SCRAPER_MAX_QUERY_VARIANTS=3
JOB_SCRAPER_MAX_WORKERS=4
JOB_SCRAPER_FETCH_LINKEDIN_DESCRIPTION=false
JOB_SCRAPER_VERBOSE=0
JOB_SCRAPER_USE_SYSTEM_CERTS=true
# Optional: path to a CA bundle used for all JobSpy HTTPS requests.
# Use this if your network intercepts TLS and the CA is not in Python's bundle.
JOB_SCRAPER_CA_CERT=
SCRAPER_API_COUNTRY_CODE=in
SCRAPER_API_USE_PROXY=true
SCRAPER_API_RENDER_ON_RETRY=true
SCRAPER_API_PREMIUM_ON_RETRY=false
# Backward-compatible alias for JOB_SCRAPER_CA_CERT.
SCRAPER_API_CA_CERT=
DIRECT_JOB_BOARD_MAX_WORKERS=4

# Optional: comma-separated direct ATS board URLs.
# These get merged with multi-site results on page 1.
# Example:
# DIRECT_JOB_BOARD_URLS=https://boards.greenhouse.io/openai,https://jobs.lever.co/stripe
DIRECT_JOB_BOARD_URLS=
